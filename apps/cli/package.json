{
  "name": "soltrac-cli",
  "version": "0.1.0",
  "private": true,
  "description": "Solana transaction intelligence CLI — check, explain, network, program",
  "bin": {
    "soltrac": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "check": "tsx src/index.ts check",
    "network": "tsx src/index.ts network",
    "explain": "tsx src/index.ts explain",
    "program": "tsx src/index.ts program",
    "build": "tsup src/index.ts --format cjs --no-splitting --out-dir dist",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "soltrac-sdk": "workspace:*",
    "@solana/web3.js": "^1.98.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
